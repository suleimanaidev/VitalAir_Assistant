# =============================================================================
# VitalAir — SINGLE global .env (project root only)
# =============================================================================
# Copy to `.env` next to this file and fill in your values.
# Frontend (next.config.mjs) and backend (main.py) both read THIS file.
# Do NOT create frontend/.env.local or backend/.env
# =============================================================================

# Shared
WAQI_API_KEY=your_waqi_token_from_aqicn.org
VITALAIR_JWT_SECRET=change-me-to-a-long-random-string

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-min-16-chars-same-as-vitalair-jwt

# Backend (FastAPI)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/vitalair?retryWrites=true&w=majority
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
USE_MOCK_AGENTS=true
USE_CELERY=false

# Live AI agents — set ONE key (OpenAI preferred if both are set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_PROVIDER=auto
GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=
SERPER_API_KEY=

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

CHROMA_PERSIST_DIR=./chroma_store
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
