# =============================================================================
# VitalAir — SINGLE global .env (project root only)
# =============================================================================
# USER SETUP (do this once):
#   1. copy .env.example .env
#   2. Fill REQUIRED values below (MongoDB, secrets, WAQI)
#   3. npm run install:all
#   4. npm run ingest:rag          (builds FAISS knowledge index — required for RAG)
#   5. npm run dev:backend         (terminal 1)
#   6. npm run dev:frontend        (terminal 2)
#
# Frontend + backend both read THIS file only.
# Do NOT create frontend/.env.local or backend/.env
# Restart both servers after editing .env
# =============================================================================

# --- REQUIRED: Live AQI (free token from https://aqicn.org/data-platform/token/) ---
WAQI_API_KEY=your_waqi_token_from_aqicn.org

# --- REQUIRED: Auth secret (min 16 chars). Same value for both lines below. ---
VITALAIR_JWT_SECRET=change-me-to-a-long-random-string
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# --- REQUIRED: Frontend URLs (change port only if you use another port) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000

# --- REQUIRED: MongoDB Atlas (free cluster) — create at https://cloud.mongodb.com ---
# Add your IP to Network Access whitelist. Use SRV or direct host string.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/vitalair?retryWrites=true&w=majority

# --- REQUIRED: Allowed browser origins (comma-separated) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# --- AGENTS: false = real AI (needs OPENAI_API_KEY). true = offline mock (no key) ---
USE_MOCK_AGENTS=false

# --- OPTIONAL but recommended for real agents: OpenAI (https://platform.openai.com/api-keys) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_PROVIDER=auto

# --- OPTIONAL: Gemini instead of OpenAI (only if you prefer Google) ---
GEMINI_API_KEY=

# --- OPTIONAL: Google Directions API. Leave EMPTY = free OSRM routes (recommended) ---
GOOGLE_MAPS_API_KEY=

# --- OPTIONAL: Serper web search (not required for core app) ---
SERPER_API_KEY=

# --- JWT settings (defaults are fine) ---
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- RAG storage (created by npm run ingest:rag — do not edit unless you know why) ---
FAISS_INDEX_DIR=./faiss_indexes

# --- OPTIONAL: Comma-separated emails that get admin panel access ---
ADMIN_EMAILS=you@example.com
